{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vibe DB",
  "version": "0.2.5",
  "identifier": "kh.com.vibedb.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeDB",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "VibeDB",
    "shortDescription": "Cross-platform SQLite database manager",
    "longDescription": "Open source database management app built with Tauri",
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ1RDVERTlEMTZEMEUzN0MKUldSODQ5QVduZDdWMWRHT3VMNzhpWFhpRzBBTUNaZVQ3a1o5Y2ZzUFRyejN0a3ZvbXdlRHpJQjIK",
      "endpoints": [
        "https://github.com/Rithprohos/Vibe-DB/releases/latest/download/latest.json"
      ]
    }
  }
}
