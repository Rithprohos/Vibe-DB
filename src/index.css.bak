@import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap");

:root {
  /* Neon DB × Supabase color palette */
  --bg-primary: #0a0a0f;
  --bg-secondary: #111118;
  --bg-tertiary: #1a1a24;
  --bg-surface: #16161f;
  --bg-elevated: #1e1e2a;
  --bg-hover: #1c1c28;
  --bg-active: #252535;
  --bg-row-alt: rgba(255, 255, 255, 0.015);

  /* Neon accent - signature green */
  --accent-primary: #00e599;
  --accent-primary-hover: #00cc88;
  --accent-primary-dim: rgba(0, 229, 153, 0.12);
  --accent-primary-glow: rgba(0, 229, 153, 0.25);
  --accent-primary-subtle: rgba(0, 229, 153, 0.06);

  /* Secondary accent - electric purple */
  --accent-secondary: #7c3aed;
  --accent-secondary-dim: rgba(124, 58, 237, 0.15);

  /* Supabase-inspired type colors */
  --type-int: #60a5fa;
  --type-text: #34d399;
  --type-real: #f59e0b;
  --type-blob: #a78bfa;
  --type-bool: #fb923c;
  --type-date: #f472b6;
  --type-default: #9898a6;

  /* Text colors */
  --text-primary: #ededed;
  --text-secondary: #8f8f8f;
  --text-tertiary: #5f5f6f;
  --text-accent: #00e599;
  --text-error: #ef4444;
  --text-warning: #f59e0b;
  --text-null: #5f5f6f;

  /* Border colors */
  --border-primary: #2a2a3a;
  --border-secondary: #1e1e2a;
  --border-accent: rgba(0, 229, 153, 0.3);
  --border-grid: #1e1e2e;

  /* Shadows */
  --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.4);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.5);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.6);
  --shadow-glow: 0 0 20px rgba(0, 229, 153, 0.08);

  /* Spacing */
  --sidebar-width: 260px;
  --statusbar-height: 32px;
  --tabbar-height: 40px;

  /* Radius */
  --radius-xs: 3px;
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;

  /* Transitions */
  --transition-fast: 120ms ease;
  --transition-normal: 200ms ease;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body, #root {
  height: 100%;
  width: 100%;
  overflow: hidden;
}

body {
  font-family: "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-size: 13px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  user-select: none;
  -webkit-user-select: none;
}

input,
textarea,
[contenteditable="true"],
.selectable-text,
.data-grid td,
.sql-editor * {
  user-select: text;
  -webkit-user-select: text;
}

/* ========== Selection ========== */
::selection {
  background: var(--accent-primary-dim);
  color: var(--text-primary);
}

/* ========== Scrollbar ========== */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.15);
}

::-webkit-scrollbar-corner {
  background: transparent;
}

/* ========== App Layout ========== */
.app-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100vw;
}

.app-main {
  display: flex;
  flex: 1;
  min-height: 0;
}

/* ========== Sidebar ========== */
.sidebar {
  width: var(--sidebar-width);
  min-width: var(--sidebar-width);
  background: var(--bg-secondary);
  border-right: 1px solid var(--border-primary);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.sidebar-header {
  padding: 14px 16px;
  border-bottom: 1px solid var(--border-secondary);
  display: flex;
  align-items: center;
  gap: 10px;
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 8px;
}

.sidebar-logo .logo-icon {
  width: 26px;
  height: 26px;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  border-radius: 7px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  color: #fff;
  box-shadow: 0 2px 8px rgba(0, 229, 153, 0.2);
}

.sidebar-logo .logo-text {
  font-size: 15px;
  font-weight: 700;
  background: linear-gradient(135deg, var(--accent-primary) 0%, #4ade80 50%, var(--accent-secondary) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.3px;
}

/* Connection card (Supabase-inspired) */
.sidebar-connection {
  padding: 10px 12px;
  border-bottom: 1px solid var(--border-secondary);
}

.connection-btn {
  width: 100%;
  padding: 8px 12px;
  background: var(--accent-primary-dim);
  border: 1px solid rgba(0, 229, 153, 0.2);
  border-radius: var(--radius-sm);
  color: var(--accent-primary);
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-fast);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-family: inherit;
}

.connection-btn:hover {
  background: var(--accent-primary-glow);
  border-color: rgba(0, 229, 153, 0.4);
  box-shadow: var(--shadow-glow);
}

/* Connection info card */
.connection-info {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  background: var(--bg-tertiary);
  border-radius: var(--radius-sm);
  border: 1px solid var(--border-secondary);
}

.connection-info .conn-icon {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, #1e3a5f, #0f2744);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
  border: 1px solid rgba(96, 165, 250, 0.2);
}

.connection-info .conn-details {
  flex: 1;
  min-width: 0;
}

.connection-info .conn-name {
  font-size: 12px;
  font-weight: 600;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.connection-info .conn-type {
  font-size: 10px;
  color: var(--text-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-top: 1px;
}

/* Sidebar quick actions */
.sidebar-actions {
  padding: 8px 12px;
  display: flex;
  gap: 6px;
  border-bottom: 1px solid var(--border-secondary);
}

.sidebar-actions button {
  flex: 1;
  padding: 6px 8px;
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xs);
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-size: 11px;
  cursor: pointer;
  transition: all var(--transition-fast);
  font-family: inherit;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.sidebar-actions button:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
  border-color: var(--border-accent);
}

.sidebar-search {
  padding: 8px 12px;
  border-bottom: 1px solid var(--border-secondary);
}

.sidebar-search input {
  width: 100%;
  padding: 7px 10px;
  background: var(--bg-primary);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xs);
  color: var(--text-primary);
  font-size: 12px;
  outline: none;
  font-family: inherit;
  transition: border-color var(--transition-fast);
}

.sidebar-search input:focus {
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 2px var(--accent-primary-subtle);
}

.sidebar-search input::placeholder {
  color: var(--text-tertiary);
}

.sidebar-objects {
  flex: 1;
  overflow-y: auto;
  padding: 6px 0;
}

.object-group {
  margin-bottom: 2px;
}

.object-group-header {
  display: flex;
  align-items: center;
  padding: 6px 14px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-tertiary);
  font-weight: 600;
  cursor: pointer;
  user-select: none;
  transition: color var(--transition-fast);
}

.object-group-header:hover {
  color: var(--text-secondary);
}

.object-group-header .arrow {
  margin-right: 6px;
  transition: transform var(--transition-fast);
  font-size: 8px;
  opacity: 0.7;
}

.object-group-header .arrow.open {
  transform: rotate(90deg);
}

.object-group-header .count {
  margin-left: auto;
  background: var(--bg-primary);
  padding: 1px 7px;
  border-radius: 10px;
  font-size: 10px;
  color: var(--text-tertiary);
}

.object-item {
  display: flex;
  align-items: center;
  padding: 6px 14px 6px 28px;
  font-size: 12.5px;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all var(--transition-fast);
  gap: 8px;
  border-left: 2px solid transparent;
}

.object-item:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
}

.object-item.active {
  background: var(--accent-primary-subtle);
  color: var(--accent-primary);
  border-left-color: var(--accent-primary);
}

.object-item .icon {
  font-size: 13px;
  width: 18px;
  text-align: center;
  flex-shrink: 0;
  opacity: 0.7;
}

.object-item.active .icon {
  opacity: 1;
}

.object-item .name {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-weight: 450;
}

/* Sidebar empty state */
.sidebar-empty {
  padding: 32px 20px;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 12px;
  line-height: 1.7;
}

.sidebar-empty .empty-icon {
  font-size: 28px;
  margin-bottom: 10px;
  opacity: 0.4;
}

.sidebar-empty .empty-hint {
  margin-top: 6px;
  font-size: 11px;
  color: var(--text-tertiary);
  opacity: 0.7;
}

/* ========== Content Area ========== */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  background: var(--bg-primary);
}

/* ========== Tab Bar (Supabase-style) ========== */
.tab-bar {
  display: flex;
  align-items: stretch;
  height: var(--tabbar-height);
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-primary);
  overflow-x: auto;
  padding-left: 0;
}

.tab-bar::-webkit-scrollbar {
  height: 0;
}

.tab-item {
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 8px;
  font-size: 12px;
  color: var(--text-secondary);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  border-right: 1px solid var(--border-secondary);
  white-space: nowrap;
  transition: all var(--transition-fast);
  min-width: 0;
  position: relative;
  font-weight: 450;
}

.tab-item:hover {
  color: var(--text-primary);
  background: var(--bg-hover);
}

.tab-item.active {
  color: var(--text-primary);
  border-bottom-color: var(--accent-primary);
  background: var(--bg-primary);
  font-weight: 500;
}

.tab-item .tab-icon {
  font-size: 12px;
  flex-shrink: 0;
  opacity: 0.6;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-item .tab-label {
  overflow: hidden;
  text-overflow: ellipsis;
}

.tab-item .tab-close {
  font-size: 13px;
  opacity: 0;
  transition: opacity var(--transition-fast);
  padding: 2px 4px;
  border-radius: 3px;
  line-height: 1;
  flex-shrink: 0;
  margin-left: 4px;
}

.tab-item:hover .tab-close {
  opacity: 0.5;
}

.tab-item .tab-close:hover {
  opacity: 1;
  background: var(--bg-active);
}

.tab-add {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  min-width: 36px;
  color: var(--text-tertiary);
  cursor: pointer;
  font-size: 16px;
  transition: all var(--transition-fast);
  border-right: 1px solid var(--border-secondary);
}

.tab-add:hover {
  color: var(--accent-primary);
  background: var(--bg-hover);
}

/* ========== Status Bar (Supabase-style) ========== */
.status-bar {
  height: var(--statusbar-height);
  min-height: var(--statusbar-height);
  background: var(--bg-secondary);
  border-top: 1px solid var(--border-primary);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 20px;
  font-size: 11px;
  color: var(--text-tertiary);
}

.status-item {
  display: flex;
  align-items: center;
  gap: 5px;
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--accent-primary);
  box-shadow: 0 0 8px var(--accent-primary);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.status-dot.disconnected {
  background: var(--text-tertiary);
  box-shadow: none;
  animation: none;
}

/* ========== Welcome Screen ========== */
.welcome-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  text-align: center;
  gap: 20px;
  background:
    radial-gradient(ellipse at 30% 50%, rgba(0, 229, 153, 0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 50%, rgba(124, 58, 237, 0.03) 0%, transparent 50%);
}

.welcome-logo {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, var(--accent-primary), #4ade80, var(--accent-secondary));
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 800;
  color: #fff;
  box-shadow: 0 12px 40px rgba(0, 229, 153, 0.2), 0 0 0 1px rgba(0, 229, 153, 0.1);
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-10px) rotate(2deg); }
}

.welcome-title {
  font-size: 32px;
  font-weight: 700;
  background: linear-gradient(135deg, var(--accent-primary), #4ade80, var(--accent-secondary));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: -0.5px;
}

.welcome-subtitle {
  font-size: 14px;
  color: var(--text-secondary);
  max-width: 420px;
  line-height: 1.7;
}

.welcome-actions {
  display: flex;
  gap: 12px;
  margin-top: 12px;
}

.welcome-btn {
  padding: 11px 28px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-normal);
  font-family: inherit;
  border: none;
}

.welcome-btn.primary {
  background: var(--accent-primary);
  color: #000;
  font-weight: 600;
}

.welcome-btn.primary:hover {
  background: var(--accent-primary-hover);
  box-shadow: 0 4px 24px rgba(0, 229, 153, 0.35);
  transform: translateY(-1px);
}

.welcome-btn.secondary {
  background: var(--bg-elevated);
  color: var(--text-primary);
  border: 1px solid var(--border-primary);
}

.welcome-btn.secondary:hover {
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-glow);
}

.welcome-recent {
  margin-top: 32px;
  width: 100%;
  max-width: 480px;
}

.welcome-recent h3 {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--text-tertiary);
  margin-bottom: 12px;
  font-weight: 600;
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  background: var(--bg-surface);
  border: 1px solid var(--border-secondary);
  border-radius: var(--radius-sm);
  margin-bottom: 8px;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.recent-item:hover {
  border-color: rgba(0, 229, 153, 0.2);
  background: var(--bg-elevated);
  box-shadow: var(--shadow-glow);
  transform: translateY(-1px);
}

.recent-item .icon {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-sm);
  background: linear-gradient(135deg, #1e3a5f, #0f2744);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  flex-shrink: 0;
  border: 1px solid rgba(96, 165, 250, 0.15);
}

.recent-item .info {
  text-align: left;
  min-width: 0;
  flex: 1;
}

.recent-item .info .name {
  font-size: 13px;
  font-weight: 500;
  color: var(--text-primary);
}

.recent-item .info .path {
  font-size: 11px;
  color: var(--text-tertiary);
  margin-top: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========== Table View (Supabase spreadsheet-style) ========== */
.table-view {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.table-toolbar {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  gap: 6px;
  border-bottom: 1px solid var(--border-primary);
  background: var(--bg-secondary);
}

.table-toolbar .toolbar-group {
  display: flex;
  align-items: center;
  gap: 4px;
}

.toolbar-btn {
  padding: 5px 10px;
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xs);
  background: transparent;
  color: var(--text-secondary);
  font-size: 11.5px;
  cursor: pointer;
  transition: all var(--transition-fast);
  font-family: inherit;
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
}

.toolbar-btn:hover {
  background: var(--bg-hover);
  color: var(--text-primary);
  border-color: var(--border-accent);
}

.toolbar-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.toolbar-btn.primary {
  background: var(--accent-primary-dim);
  color: var(--accent-primary);
  border-color: rgba(0, 229, 153, 0.2);
}

.toolbar-btn.primary:hover {
  background: var(--accent-primary-glow);
}

.toolbar-btn.danger:hover {
  border-color: var(--text-error);
  color: var(--text-error);
}

.toolbar-separator {
  width: 1px;
  height: 20px;
  background: var(--border-primary);
  margin: 0 4px;
}

.toolbar-spacer {
  flex: 1;
}

.row-count-badge {
  font-size: 11px;
  color: var(--text-tertiary);
  padding: 3px 10px;
  background: var(--bg-primary);
  border-radius: 10px;
  font-weight: 500;
  font-variant-numeric: tabular-nums;
}

.pagination-info {
  font-size: 11px;
  color: var(--text-tertiary);
  font-variant-numeric: tabular-nums;
}

/* Supabase-style spreadsheet grid */
.data-grid-wrapper {
  flex: 1;
  overflow: auto;
  position: relative;
}

.data-grid {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
  table-layout: auto;
}

.data-grid th {
  position: sticky;
  top: 0;
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  font-weight: 500;
  padding: 0 14px;
  height: 36px;
  text-align: left;
  border-bottom: 1px solid var(--border-primary);
  border-right: 1px solid var(--border-grid);
  white-space: nowrap;
  font-size: 12px;
  cursor: pointer;
  user-select: none;
  z-index: 2;
  transition: color var(--transition-fast);
}

.data-grid th:last-child {
  border-right: none;
}

.data-grid th:hover {
  color: var(--text-primary);
}

.data-grid th .col-name {
  display: flex;
  align-items: center;
  gap: 6px;
}

.data-grid th .col-type {
  font-size: 9px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  padding: 1px 5px;
  border-radius: 3px;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.04);
  color: var(--text-tertiary);
}

.data-grid th .sort-icon {
  margin-left: 4px;
  font-size: 9px;
  opacity: 0.6;
}

/* Row number column */
.data-grid th.row-num-col,
.data-grid td.row-num-col {
  width: 52px;
  min-width: 52px;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 11px;
  background: var(--bg-tertiary);
  border-right: 1px solid var(--border-primary);
  position: sticky;
  left: 0;
  z-index: 1;
  font-variant-numeric: tabular-nums;
}

.data-grid td.row-num-col {
  background: var(--bg-secondary);
  font-size: 10.5px;
}

.data-grid td {
  padding: 0 14px;
  height: 34px;
  border-bottom: 1px solid var(--border-grid);
  border-right: 1px solid var(--border-grid);
  white-space: nowrap;
  max-width: 320px;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
  transition: background var(--transition-fast);
}

.data-grid td:last-child {
  border-right: none;
}

.data-grid tbody tr:nth-child(even) td:not(.row-num-col) {
  background: var(--bg-row-alt);
}

.data-grid tbody tr:hover td {
  background: var(--bg-hover) !important;
}

.data-grid tbody tr:hover td.row-num-col {
  background: var(--bg-tertiary) !important;
  color: var(--text-secondary);
}

.data-grid td.null-value {
  color: var(--text-null);
  font-style: italic;
  font-size: 11px;
}

.data-grid td.number-value {
  color: var(--type-int);
}

.data-grid td.bool-value {
  color: var(--type-bool);
}

/* ========== Query Editor ========== */
.query-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.query-editor-area {
  display: flex;
  flex-direction: column;
  min-height: 200px;
  max-height: 50%;
  border-bottom: 2px solid var(--border-primary);
}

.query-toolbar {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  gap: 8px;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-secondary);
}

.run-btn {
  padding: 5px 16px;
  background: var(--accent-primary);
  color: #000;
  border: none;
  border-radius: var(--radius-xs);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition-fast);
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: inherit;
}

.run-btn:hover {
  background: var(--accent-primary-hover);
  box-shadow: 0 2px 12px rgba(0, 229, 153, 0.3);
}

.run-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.query-editor-textarea {
  flex: 1;
  resize: none;
  padding: 14px 16px;
  background: var(--bg-primary);
  color: var(--text-primary);
  border: none;
  outline: none;
  font-family: "JetBrains Mono", monospace;
  font-size: 13px;
  line-height: 1.7;
  tab-size: 2;
  caret-color: var(--accent-primary);
}

.query-editor-textarea::placeholder {
  color: var(--text-tertiary);
  font-style: italic;
}

.query-results {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.query-results-header {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-secondary);
  gap: 8px;
  font-size: 12px;
  color: var(--text-secondary);
}

.query-results-header .result-tag {
  padding: 2px 10px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2px;
}

.query-results-header .result-tag.success {
  background: var(--accent-primary-dim);
  color: var(--accent-primary);
}

.query-results-header .result-tag.error {
  background: rgba(239, 68, 68, 0.12);
  color: var(--text-error);
}

.query-error {
  padding: 16px;
  color: var(--text-error);
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
  background: rgba(239, 68, 68, 0.04);
  line-height: 1.6;
}

.query-empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 13px;
  gap: 6px;
}

.query-empty .empty-hint {
  font-size: 11px;
  opacity: 0.6;
}

/* ========== Table Structure (Supabase-style) ========== */
.structure-view {
  flex: 1;
  overflow: auto;
  padding: 0;
}

.structure-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12.5px;
}

.structure-table th {
  background: var(--bg-tertiary);
  padding: 10px 14px;
  text-align: left;
  font-weight: 500;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-tertiary);
  border-bottom: 1px solid var(--border-primary);
  border-right: 1px solid var(--border-grid);
  position: sticky;
  top: 0;
  z-index: 1;
}

.structure-table th:last-child {
  border-right: none;
}

.structure-table td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border-grid);
  border-right: 1px solid var(--border-grid);
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
}

.structure-table td:last-child {
  border-right: none;
}

.structure-table tr:hover td {
  background: var(--bg-hover);
}

.pk-badge {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 2px 8px;
  background: var(--accent-primary-dim);
  color: var(--accent-primary);
  border-radius: var(--radius-xs);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.3px;
}

.type-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: var(--radius-xs);
  font-size: 11px;
  font-weight: 500;
  font-family: "JetBrains Mono", monospace;
}

.type-badge.int { background: rgba(96, 165, 250, 0.12); color: var(--type-int); }
.type-badge.text { background: rgba(52, 211, 153, 0.12); color: var(--type-text); }
.type-badge.real { background: rgba(245, 158, 11, 0.12); color: var(--type-real); }
.type-badge.blob { background: rgba(167, 139, 250, 0.12); color: var(--type-blob); }
.type-badge.date { background: rgba(244, 114, 182, 0.12); color: var(--type-date); }
.type-badge.default { background: rgba(255, 255, 255, 0.04); color: var(--type-default); }

.notnull-badge {
  display: inline-block;
  padding: 2px 8px;
  background: rgba(245, 158, 11, 0.1);
  color: var(--text-warning);
  border-radius: var(--radius-xs);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.3px;
}

/* ========== Connection Dialog ========== */
.dialog-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 150ms ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.dialog {
  background: var(--bg-surface);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg), 0 0 60px rgba(0, 0, 0, 0.4);
  width: 460px;
  max-width: 90vw;
  animation: slideUp 250ms cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(16px) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.dialog-header {
  padding: 24px 24px 0;
}

.dialog-header h2 {
  font-size: 18px;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.2px;
}

.dialog-header p {
  font-size: 13px;
  color: var(--text-secondary);
  margin-top: 4px;
}

.dialog-body {
  padding: 20px 24px;
}

.form-group {
  margin-bottom: 18px;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-group label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 6px;
}

.form-group input {
  width: 100%;
  padding: 9px 12px;
  background: var(--bg-primary);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xs);
  color: var(--text-primary);
  font-size: 13px;
  outline: none;
  font-family: inherit;
  transition: all var(--transition-fast);
}

.form-group input:focus {
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 2px var(--accent-primary-subtle);
}

.form-group .file-input {
  display: flex;
  gap: 6px;
}

.form-group .file-input input {
  flex: 1;
  font-family: "JetBrains Mono", monospace;
  font-size: 12px;
}

.form-group .browse-btn {
  padding: 9px 14px;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xs);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 12px;
  white-space: nowrap;
  transition: all var(--transition-fast);
  font-family: inherit;
  font-weight: 500;
}

.form-group .browse-btn:hover {
  border-color: var(--accent-primary);
  color: var(--text-primary);
  background: var(--bg-hover);
}

.dialog-footer {
  padding: 0 24px 24px;
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.dialog-btn {
  padding: 9px 20px;
  border-radius: var(--radius-xs);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-fast);
  font-family: inherit;
  border: none;
}

.dialog-btn.cancel {
  background: transparent;
  color: var(--text-secondary);
  border: 1px solid var(--border-primary);
}

.dialog-btn.cancel:hover {
  color: var(--text-primary);
  background: var(--bg-hover);
}

.dialog-btn.connect {
  background: var(--accent-primary);
  color: #000;
  font-weight: 600;
}

.dialog-btn.connect:hover {
  background: var(--accent-primary-hover);
  box-shadow: 0 2px 16px rgba(0, 229, 153, 0.3);
}

/* ========== View Toggle ========== */
.view-toggle {
  display: flex;
  align-items: center;
  background: var(--bg-primary);
  border-radius: var(--radius-xs);
  border: 1px solid var(--border-primary);
  overflow: hidden;
}

.view-toggle button {
  padding: 4px 12px;
  background: none;
  border: none;
  color: var(--text-tertiary);
  font-size: 11px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition-fast);
  font-family: inherit;
}

.view-toggle button.active {
  background: var(--accent-primary-dim);
  color: var(--accent-primary);
}

.view-toggle button:hover:not(.active) {
  color: var(--text-primary);
}

/* ========== Loading ========== */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
  color: var(--text-tertiary);
  gap: 10px;
  font-size: 12px;
}

.spinner {
  width: 14px;
  height: 14px;
  border: 2px solid var(--border-primary);
  border-top-color: var(--accent-primary);
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== Resizer ========== */
.resizer {
  width: 4px;
  cursor: col-resize;
  background: transparent;
  transition: background var(--transition-fast);
}

.resizer:hover,
.resizer.active {
  background: var(--accent-primary);
}

.resizer-h {
  height: 4px;
  cursor: row-resize;
  background: transparent;
  transition: background var(--transition-fast);
  z-index: 10;
}

.resizer-h:hover,
.resizer-h.active {
  background: var(--accent-primary);
}

/* Global resizing states to prevent text selection glitch */
body.is-resizing {
  cursor: col-resize !important;
  user-select: none !important;
  -webkit-user-select: none !important;
}

body.is-resizing-h {
  cursor: row-resize !important;
  user-select: none !important;
  -webkit-user-select: none !important;
}

/* TanStack Table Specifics */
.data-grid th {
  position: relative;
}

.column-resizer {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  width: 5px;
  background: transparent;
  cursor: col-resize;
  user-select: none;
  touch-action: none;
  z-index: 1;
}

.column-resizer.isResizing {
  background: var(--accent-primary);
  opacity: 1;
}

.data-grid th:hover .column-resizer {
  background: var(--border-primary);
}

/* In-place Row Adding Styles */
.dirty-row {
  background-color: rgba(245, 158, 11, 0.1) !important;
  border-top: 1px solid var(--type-real) !important;
  border-bottom: 1px solid var(--type-real) !important;
}

.dirty-row td {
  border-color: rgba(245, 158, 11, 0.2) !important;
  position: relative;
}

.dirty-row .row-num-col {
  color: var(--type-real);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}

.cell-input {
  width: 100%;
  height: 100%;
  background: transparent;
  border: none;
  color: var(--text-primary);
  font-family: inherit;
  font-size: inherit;
  outline: none;
  padding: 0;
  margin: 0;
}

.cell-input::placeholder {
  color: var(--text-tertiary);
  font-style: italic;
  opacity: 0.5;
}

.toolbar-btn.success {
  background: var(--accent-primary);
  color: #000;
  border-color: var(--accent-primary);
  font-weight: 600;
}

.toolbar-btn.success:hover {
  background: var(--accent-primary-hover);
  box-shadow: 0 0 12px rgba(0, 229, 153, 0.3);
}

.toolbar-btn.link-danger {
  background: transparent;
  border: none;
  color: var(--text-secondary);
  text-decoration: underline;
  text-underline-offset: 3px;
}

.toolbar-btn.link-danger:hover {
  color: var(--text-error);
  background: transparent;
}

/* SQL Log Drawer */
.log-drawer {
  position: fixed;
  bottom: 34px; /* Right above status bar */
  right: 12px;
  width: 400px;
  max-height: 500px;
  background: var(--bg-secondary);
  border: 1px solid var(--border-primary);
  border-bottom: none;
  border-radius: 8px 8px 0 0;
  box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  z-index: 1000;
  animation: slideUp 0.2s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.log-drawer-header {
  padding: 10px 12px;
  border-bottom: 1px solid var(--border-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-primary);
  border-radius: 8px 8px 0 0;
}

.log-drawer-title {
  font-weight: 600;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--text-secondary);
}

.log-drawer-actions {
  display: flex;
  gap: 8px;
}

.log-drawer-btn {
  background: transparent;
  border: none;
  color: var(--text-tertiary);
  font-size: 11px;
  cursor: pointer;
  padding: 2px 6px;
  border-radius: 4px;
}

.log-drawer-btn:hover {
  background: var(--bg-tertiary);
  color: var(--text-primary);
}

.log-drawer-btn.close {
  color: var(--text-error);
}

.log-drawer-content {
  flex: 1;
  overflow-y: auto;
  padding: 8px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.log-empty {
  padding: 40px;
  text-align: center;
  color: var(--text-tertiary);
  font-style: italic;
}

.log-item {
  padding: 8px;
  background: var(--bg-primary);
  border: 1px solid var(--border-secondary);
  border-radius: 4px;
  font-size: 11px;
}

.log-item.error {
  border-left: 3px solid var(--text-error);
}

.log-item.success {
  border-left: 3px solid var(--accent-primary);
}

.log-item-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
  color: var(--text-tertiary);
}

.log-status-tag {
  font-weight: 700;
  font-size: 9px;
  padding: 1px 4px;
  border-radius: 2px;
}

.log-status-tag.success {
  background: rgba(0, 229, 153, 0.1);
  color: var(--accent-primary);
}

.log-status-tag.error {
  background: rgba(239, 68, 68, 0.1);
  color: var(--text-error);
}

.log-duration {
  margin-left: auto;
}

.log-copy-btn {
  background: var(--bg-tertiary);
  border: none;
  color: var(--text-secondary);
  font-size: 10px;
  padding: 2px 6px;
  border-radius: 3px;
  cursor: pointer;
}

.log-copy-btn:hover {
  background: var(--accent-primary);
  color: #000;
}

.log-sql {
  background: var(--bg-secondary);
  padding: 6px;
  border-radius: 4px;
  word-break: break-all;
  white-space: pre-wrap;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
  color: var(--text-secondary);
}

.log-error-msg {
  margin-top: 6px;
  color: var(--text-error);
  font-size: 10px;
}

.status-bar-item.clickable {
  cursor: pointer;
}

.status-bar-item.clickable:hover {
  background: var(--bg-tertiary);
  color: var(--text-primary);
}

.status-bar-item.active {
  background: var(--bg-tertiary);
  color: var(--accent-primary);
}


